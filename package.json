{
  "name": "@shashank-sn/organisation-md",
  "version": "0.1.0",
  "description": "Your organization's memory layer — an MCP server backed by a git repo.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "organisation-md": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "octokit": "^4.1.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
